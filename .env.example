# MiMo Token Plan API key (tp-...)
MIMO_API_KEY=tp-your-key-here

# Endpoint (default: Token Plan Singapore)
MIMO_ENDPOINT=https://token-plan-sgp.xiaomimimo.com/v1

# Model selection
MIMO_MODEL=mimo-v2.5-pro

# Optional: lighter model for cheap operations (parsing, classification)
MIMO_MODEL_LITE=mimo-v2-flash

# Output directory for generated DOCX files
OUTPUT_DIR=./output
